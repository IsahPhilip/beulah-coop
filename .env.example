# Beulah Coop Environment Configuration Example
# Copy this file to .env and configure for your environment

# Application
APP_NAME="Beulah Multi-Purpose Cooperative Society Ltd."
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/codes/beulah-coop

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=beulah_coop
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_LIFETIME=1800
SESSION_NAME=beulah_session
SESSION_DRIVER=files

# Security
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_PROFILES_DIR=uploads/profiles/
ALLOWED_IMAGE_TYPES=jpeg,png,gif,webp

# Email Configuration (for 2FA and notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@beulahcoop.local
MAIL_FROM_NAME="${APP_NAME}"

# Two-Factor Authentication
2FA_CODE_LENGTH=6
2FA_CODE_EXPIRY=600
2FA_ISSUER="Beulah Coop"

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_TABLE=audit_logs

# Timezone
TIMEZONE=Africa/Lagos

# Date Format
DATE_FORMAT=Y-m-d
DATETIME_FORMAT=Y-m-d H:i:s
DISPLAY_DATE_FORMAT=d M Y, h:i A